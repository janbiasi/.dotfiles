{
  "mcpServers": {
    "context7": {
      "url": "https://mcp.context7.com/mcp",
      "auth": "bearer",
      "headers": {
        "CONTEXT7_API_KEY": "$env:CONTEXT7_API_KEY"
      }
    },
    "chrome-devtools": {
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp@latest"],
      "directTools": true
    },
    "github": {
      "url": "https://api.githubcopilot.com/mcp/",
      "auth": "bearer",
      "bearerToken": "$env:GITHUB_TOKEN"
    }
  }
}
