# Better ls command
alias ls='eza --git --icons --color=always --group-directories-first'

# Alias ll to a better variant
alias ll='ls -la'

# Convenience for git & lazygit
alias g='git'
alias lg='lazygit'

# Neovim aliases
alias vim='nvim'
alias vi='nvim'

# Terraform alias
alias tf='terraform'

# Devbox alias
alias d='devbox'
alias d-up='devbox services up'

# Tmux stuff
alias qs='tv sesh'
alias tn='tmux new-session -A -s "$(basename "$PWD")"'

# Useful parent cd aliases
alias ..='cd ..'
alias ...='cd ../../'
alias ....='cd ../../../../'
alias .....='cd ../../../../../'

# Convenience alias for Spring projects
alias spring-dev="./gradlew bootRun --args='--spring.profiles.active=dev'"

# AI aliases
alias serenax="uvx --from git+https://github.com/oraios/serena serena"
